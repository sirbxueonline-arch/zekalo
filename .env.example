# ─────────────────────────────────────────────────────────────
#  ZIRVA — Environment variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in the real values.
#  Never commit `.env.local` — it's already in .gitignore.
#
#  Vite exposes anything prefixed with VITE_ to the browser.
#  Anything else is server-side only (Supabase Edge Functions).
# ─────────────────────────────────────────────────────────────


# ─── Supabase ─── (required)
# Find in Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ─── Anthropic (Zeka AI) ─── (required for AI features)
# DO NOT put this in a VITE_ variable — it would be exposed to the browser.
# Set it as a Supabase Edge Function secret instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# The edge function `supabase/functions/zeka-chat/` reads it server-side.
ANTHROPIC_API_KEY=sk-ant-...


# ─── EmailJS ─── (required for contact form / pilot request)
# Find at emailjs.com → Account → API Keys + Email Services + Templates
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxx


# ─── Sentry ─── (optional — error monitoring)
# Get DSN from sentry.io → Project Settings → Client Keys
# Leave blank to disable Sentry in development.
VITE_SENTRY_DSN=


# ─────────────────────────────────────────────────────────────
#  Production deploy (Vercel)
# ─────────────────────────────────────────────────────────────
#  In Vercel → Project Settings → Environment Variables, add the
#  same VITE_* keys above for Production + Preview.
#  ANTHROPIC_API_KEY goes in Supabase secrets, not Vercel.
# ─────────────────────────────────────────────────────────────
